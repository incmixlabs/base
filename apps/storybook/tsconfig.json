      "@incmix/core/declarative-ui.examples": ["../../packages/core/src/declarative-ui.examples.ts"],
      "@incmix/react": ["../../packages/react/src/index.tsx"],
      "@incmix/react-runner": ["../../packages/react-runner/src/index.ts"],
      "@incmix/theme": ["../../packages/theme/src/index.ts"],
      "@incmix/ui": ["../../packages/ui/src/index.ts"]
