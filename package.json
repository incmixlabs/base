{
  "name": "incmix-autoform",
  "version": "0.0.0",
  "private": true,
  "description": "Public-facing frontend monorepo for Incmix UI, Autoform, and docs packages.",
  "license": "MIT",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:docs": "pnpm --filter @incmix/docs dev",
    "dev:storybook": "pnpm --filter @incmix/storybook dev",
    "lint": "pnpm -r --if-present lint",
    "packages": "pnpm -r list --depth -1",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
