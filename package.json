{
  "name": "incmix",
  "version": "0.0.0",
  "private": true,
  "description": "Public-facing frontend monorepo for Incmix UI, Theme, and Storybook.",
  "license": "MIT",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:analyze": "pnpm --filter @incmix/ui build:analyze && pnpm --filter @incmix/ui build:analyze:lib",
    "audit:af-vars": "node scripts/audit-af-vars.mjs",
    "check:react-compiler": "node scripts/check-react-compiler-health.mjs",
    "dev": "pnpm dev:storybook",
    "dev:storybook": "pnpm --filter @incmix/ui dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "packages": "pnpm -r list --depth -1",
    "prepare": "husky",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "husky": "catalog:",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "5.0.6",
      "ws": "8.20.1"
    }
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
