{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "outDir": "./dist",
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@incmix/ajv": ["../ajv/src/index.ts"],
      "@incmix/core": ["../core/src/index.ts"],
      "@incmix/core/declarative-ui.examples": ["../core/src/declarative-ui.examples.ts"],
      "@incmix/react": ["../react/src/index.tsx"],
      "@incmix/react-runner": ["../react-runner/src/index.ts"],
      "@incmix/theme": ["../theme/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": [
    "dist",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/stories/**",
    "src/form/date/**/*.test.tsx",
    "src/theme/helpers/**",
    "src/_internal/base-button.tsx"
  ]
}
