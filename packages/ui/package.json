    },
    "./status-page": {
      "types": "./dist/status-page/index.d.ts",
      "import": "./dist/status-page.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme.js"
    },
    "./theme/contract": {
      "types": "./dist/theme/contract/theme-contract.d.ts",
