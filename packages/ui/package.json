    },
    "./utils/date": {
      "types": "./dist/utils/date.d.ts",
      "import": "./dist/utils/date.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@incmix/config": "workspace:*",
    "@radix-ui/colors": "^3.0.0",
