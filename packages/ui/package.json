{
  "name": "@incmix/ui",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "generate:theme-runtime": "tsx scripts/generate-runtime-palette-source.ts && tsx scripts/generate-design-tokens-css.ts",
    "pretypecheck": "pnpm generate:theme-runtime",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretypecheck:active": "pnpm generate:theme-runtime",
    "typecheck:active": "tsc -p tsconfig.active.json --noEmit",
    "prebuild": "pnpm generate:theme-runtime",
    "build": "tsup --config tsup.config.ts && tsc -p tsconfig.build.json",
    "postbuild": "node scripts/patch-use-client-directives.mjs && node scripts/copy-package-assets.mjs && node scripts/check-bundle-guards.mjs",
    "pretest": "pnpm generate:theme-runtime",
    "test": "vitest run",
    "test:watch": "vitest",
    "predev": "pnpm generate:theme-runtime",
    "dev": "tsup --config tsup.config.ts --watch",
    "build:analyze:lib": "vite build --config vite.analyze.config.ts",
    "check:bundle": "node scripts/check-bundle-guards.mjs",
    "generate:hues": "node scripts/generate-hue-palette.mjs",
    "generate:theme-css": "tsx scripts/generate-design-tokens-css.ts",
    "generate:tokens": "pnpm generate:theme-runtime",
    "smoke:exports": "node --import ./scripts/register-smoke-css-loader.mjs scripts/smoke-package-exports.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "import": "./dist/charts.js"
    },
    "./charts/core": {
      "types": "./dist/charts/core.d.ts",
      "import": "./dist/charts/core.js"
    },
