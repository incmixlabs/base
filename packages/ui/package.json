    "@base-ui/react": "1.2.0",
    "@incmix/theme": "workspace:*",
    "@internationalized/date": "^3.11.0",
    "@ncdai/react-wheel-picker": "^1.2.0",
    "@tanstack/react-query": "^5.91.2",
    "@vanilla-extract/dynamic": "catalog:",
