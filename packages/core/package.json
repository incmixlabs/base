{
  "name": "@incmix/core",
  "version": "3.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./declarative-ui.examples": {
      "types": "./dist/declarative-ui.examples.d.ts",
      "import": "./dist/declarative-ui.examples.mjs",
      "require": "./dist/declarative-ui.examples.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/incmixlabs/base"
  },
  "scripts": {
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "build": "tsup src/index.ts src/declarative-ui.examples.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/declarative-ui.examples.ts --format cjs,esm --dts --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@incmix/config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "ajv": "catalog:",
    "ajv-formats": "catalog:",
    "tinybase": "^8.1.1",
    "uuid": "catalog:"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
