{
  "name": "@incmix/autoform",
  "version": "0.0.0",
  "description": "Public Autoform React package for schema-driven forms.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor/index.js",
      "require": "./dist/editor/index.cjs"
    },
    "./stories/autoform-ui-schema-contract.example": {
      "types": "./dist/stories/autoform-ui-schema-contract.example.d.ts",
      "import": "./dist/stories/autoform-ui-schema-contract.example.js",
      "require": "./dist/stories/autoform-ui-schema-contract.example.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css",
    "**/*.css",
    "*.css.ts",
    "./dist/**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@incmix/ajv": "workspace:*",
    "@incmix/core": "workspace:*",
    "@incmix/react": "workspace:*",
    "@incmix/ui": "workspace:*",
    "@xstate/react": "catalog:",
    "lucide-react": "catalog:",
    "xstate": "catalog:"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vanilla-extract/css": "catalog:",
    "@vanilla-extract/esbuild-plugin": "catalog:",
    "@vanilla-extract/vite-plugin": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/incmixlabs/base"
  }
}
