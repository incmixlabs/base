{
  "extends": "../../tsconfig.base.json",
  "include": ["src"],
  "exclude": ["dist", "src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*.stories.ts", "src/**/*.stories.tsx"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["../ui/src/*"],
      "@incmix/ajv": ["../ajv/src/index.ts"],
      "@incmix/core": ["../core/src/index.ts"],
      "@incmix/react": ["../react/src/index.tsx"],
      "@incmix/theme": ["../theme/src/index.ts"],
      "@incmix/ui": ["../ui/src/index.ts"],
      "@incmix/ui/*": ["../ui/src/*"],
      "@incmix/autoform": ["./src/index.tsx"],
      "@incmix/autoform/*": ["./src/*"]
    }
  }
}
